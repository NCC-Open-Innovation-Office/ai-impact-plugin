{
  "metadata": {
    "version": "1.0.0",
    "description": "AI model energy and cost data for environmental impact calculations",
    "last_updated": "2026-05-24",
    "data_source_legend": {
      "scaled_estimate": "Energy value derived by scaling the BLOOM-176B measured baseline (0.025 Wh/1k tokens) using (params/176B)^0.8. Parameter counts for closed-source models are community estimates; no cloud-provider inference measurements are publicly available.",
      "measured": "Energy value sourced from a published direct measurement study."
    },
    "energy_unit": "Wh per 1000 tokens (input + output combined)",
    "cost_unit": "USD per 1000 tokens",
    "scientific_basis": {
      "energy": {
        "paper": "Power Hungry Processing: Watts Driving the Cost of AI Deployment?",
        "authors": "Luccioni, A.S., Jernite, Y., & Strubell, E.",
        "year": 2024,
        "venue": "ACM Conference on Fairness, Accountability, and Transparency (FACcT '24)",
        "arxiv": "2311.16863",
        "doi": "10.1145/3630106.3658542",
        "methodology": "Directly measured BLOOM-176B at 0.025 Wh/1k tokens on 8\u00d7A100 GPUs. All other model values in this file are scaled estimates using (params/176B)^0.8, with an additional 0.5\u00d7 factor for cloud-optimised deployments. Parameter counts for closed-source models (GPT-4, Claude, Gemini) are community estimates; no cloud-provider inference measurements are publicly available."
      },
      "water": {
        "paper": "Making AI Less 'Thirsty': Uncovering and Addressing the Secret Water Footprint of AI Models",
        "authors": "Li, P., Yang, J., Islam, M.A., & Ren, S.",
        "year": 2023,
        "arxiv": "2304.03271",
        "methodology": "On-site Water Usage Effectiveness (WUE) of 1.8 L/kWh used as average across major cloud data centers (Microsoft, Google). water_mL = (energy_Wh / 1000) * WUE * 1000."
      },
      "carbon": {
        "source": "US EPA eGRID 2022",
        "url": "https://www.epa.gov/egrid/download-data",
        "value_g_co2_per_kwh": 386,
        "methodology": "National US average annual carbon intensity. co2_g = (energy_Wh / 1000) * 386."
      }
    }
  },
  "constants": {
    "carbon_intensity_g_co2_per_kwh": 386.0,
    "water_usage_effectiveness_l_per_kwh": 1.8,
    "bloom_176b_baseline_wh_per_1k_tokens": 0.025,
    "scaling_exponent": 0.8,
    "cloud_efficiency_factor": 0.5
  },
