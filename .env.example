# Copy this file to .env and fill in the values before running docker compose up.

# Open WebUI admin credentials.
# The setup service uses these to authenticate and auto-register the plugins.
# On the very first run, if no accounts exist yet, the setup service will create
# this account automatically (the first user becomes admin in Open WebUI).
# On subsequent runs it just signs in with these credentials.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Display name used when the admin account is created automatically.
ADMIN_NAME=Admin

# Secret key for Open WebUI session tokens.  Change this to a random string.
WEBUI_SECRET_KEY=change_me_to_a_random_string

# (Optional) Electricity Maps API key for real-time marginal carbon intensity.
# Enables the Green Software Foundation SCI methodology instead of the static
# US EPA eGRID 2022 fallback value (386 g CO₂/kWh).
# Free tier available at https://api.electricitymap.org
# Leave blank to use the static fallback.
ELECTRICITY_MAPS_API_KEY=

# Electricity Maps zone for the data centre region that serves your AI provider.
# Only used when ELECTRICITY_MAPS_API_KEY is set.
# Examples: US-MIDA (PJM/Mid-Atlantic), US-CAL-CISO (California),
#           IE (Ireland), FR (France), DE (Germany), GB (Great Britain).
# Full zone list: https://api.electricitymap.org/v3/zones
ELECTRICITY_MAPS_ZONE=US-MIDA

# (docker-compose.ollama.yaml only)
# Ollama model to pull automatically on first start.
# Smaller models (~1 GB) run on CPU; larger ones benefit from a GPU.
# See https://ollama.com/library for available models.
OLLAMA_MODEL=llama3.2:1b
